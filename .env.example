# Conductor environment configuration
# Copy to .env and customize

CONDUCTOR_SERVICE__HOST=0.0.0.0
CONDUCTOR_SERVICE__PORT=8093

CONDUCTOR_AUTH__MODE=dev-none
CONDUCTOR_AUTH__INTERNAL_SECRET=
CONDUCTOR_AUTH__CLOUDFLARE_TEAM_DOMAIN=
CONDUCTOR_AUTH__CLOUDFLARE_AUD=

CONDUCTOR_STORAGE__SQLITE_PATH=./data/conductor.db

CONDUCTOR_OBSERVABILITY__LOG_LEVEL=INFO
CONDUCTOR_OBSERVABILITY__LOG_FORMAT=json
CONDUCTOR_OBSERVABILITY__METRICS_ENABLED=true

CONDUCTOR_ENVIRONMENT=dev

# Agents Gateway integration
CONDUCTOR_AGENTS_GATEWAY__URL=http://localhost:8092
CONDUCTOR_AGENTS_GATEWAY__AUTH_MODE=internal-only
CONDUCTOR_AGENTS_GATEWAY__INTERNAL_TOKEN=
CONDUCTOR_AGENTS_GATEWAY__TIMEOUT_SECONDS=30

# Skills Gateway integration
CONDUCTOR_SKILLS_GATEWAY__URL=http://localhost:8091
CONDUCTOR_SKILLS_GATEWAY__AUTH_MODE=dev-none
CONDUCTOR_SKILLS_GATEWAY__INTERNAL_TOKEN=
CONDUCTOR_SKILLS_GATEWAY__TIMEOUT_SECONDS=10

# Planner config
CONDUCTOR_PLANNER__MODE=manual
CONDUCTOR_PLANNER__LLM_PROVIDER=
CONDUCTOR_PLANNER__LLM_MODEL=
CONDUCTOR_PLANNER__LLM_API_KEY=

# Circuit breaker limits
CONDUCTOR_CIRCUIT__MAX_ITERATIONS_PER_RUN=50
CONDUCTOR_CIRCUIT__MAX_COST_USD_PER_RUN=10.0
CONDUCTOR_CIRCUIT__MAX_CONCURRENT_TASKS=4
CONDUCTOR_CIRCUIT__MAX_RETRIES_PER_TASK=3
CONDUCTOR_CIRCUIT__MAX_WALL_CLOCK_MINUTES=120
CONDUCTOR_CIRCUIT__MAX_STALL_MINUTES=30